{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cmux-windows",
  "version": "0.2.0",
  "identifier": "com.megum.cmux-windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cmux-windows",
        "width": 1200,
        "height": 800,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Davinci-Meg/cmux-windows/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0OUJCMUE1RUQ4NTc2QkEKUldTNmRvWHRwYkdiWkMwQ2xPbG5NYTN0OW11bXZiSmpwZFVqN05GWUJod3R6U3graVpuTXBENk8K"
    }
  }
}
